OPENAI_API_KEY=your-openai-api-key-here

# Application Environment
ENVIRONMENT=production

# API Configuration
PORT=8080
WORKERS=1
LOG_LEVEL=INFO

# Grafana Configuration (for docker-compose)
GRAFANA_PASSWORD=admin

